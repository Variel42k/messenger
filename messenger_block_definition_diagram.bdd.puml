@startuml Block Definition Diagram
!theme plain
title Блочная диаграмма определения (BDD): Структура мессенджера

package "Мессенджер Система" as System {
  
  block "Пользователь" as User {
    attribute "userId: String"
    attribute "username: String"
    attribute "email: String"
    attribute "password: String"
    attribute "role: UserRole"
    attribute "status: UserStatus"
  }

  block "Клиент" as Client {
    attribute "clientId: String"
    attribute "platform: String"
    attribute "version: String"
    attribute "connectionStatus: ConnectionStatus"
  }

  block "Сервер" as Server {
    attribute "serverId: String"
    attribute "host: String"
    attribute "port: Integer"
    attribute "status: ServerStatus"
  }

  block "База данных" as Database {
    attribute "dbId: String"
    attribute "type: DbType"
    attribute "host: String"
    attribute "port: Integer"
  }

  block "Файловое хранилище" as FileStorage {
    attribute "storageId: String"
    attribute "type: StorageType"
    attribute "endpoint: String"
    attribute "region: String"
  }

  block "Кэш-сервер" as Cache {
    attribute "cacheId: String"
    attribute "type: CacheType"
    attribute "host: String"
    attribute "port: Integer"
  }

  block "Чат" as Chat {
    attribute "chatId: String"
    attribute "name: String"
    attribute "type: ChatType"
    attribute "encrypted: Boolean"
    attribute "encryptionKey: String"
    attribute "securityLevel: SecurityLevel"
  }

  block "Сообщение" as Message {
    attribute "messageId: String"
    attribute "content: String"
    attribute "timestamp: DateTime"
    attribute "status: MessageStatus"
    attribute "encrypted: Boolean"
  }

  block "Файл" as File {
    attribute "fileId: String"
    attribute "filename: String"
    attribute "size: Long"
    attribute "contentType: String"
    attribute "uploadDate: DateTime"
  }

  block "Политики безопасности" as SecurityPolicies {
    attribute "policyId: String"
    attribute "dataRetentionDays: Integer"
    attribute "encryptionRequired: Boolean"
    attribute "maxFileSizeMB: Integer"
    attribute "allowedFileTypes: List<String>"
  }

  block "LDAP Настройки" as LdapSettings {
    attribute "ldapId: String"
    attribute "url: String"
    attribute "baseDn: String"
    attribute "userDnPattern: String"
  }

}

User ||--o{ Chat : "владеет/участвует"
User ||--o{ Message : "отправляет"
Client ||--|| Server : "подключается"
Server ||--o{ Database : "использует"
Server ||--o{ FileStorage : "использует"
Server ||--o{ Cache : "использует"
Chat ||--o{ Message : "содержит"
Message ||--o{ File : "может содержать"
Server ||--|| SecurityPolicies : "применяет"
Server ||--|| LdapSettings : "использует"

@enduml