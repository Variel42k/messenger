@startuml
title Use Case Diagram: Мессенджер

left to right direction

actor "Пользователь" as User
actor "Администратор" as Admin
actor "Система аутентификации LDAP" as LDAP

rectangle "Мессенджер" as Messenger {

  usecase "Регистрация в системе" as UC1
  usecase "Аутентификация в системе" as UC2
  usecase "Создание чата" as UC3
  usecase "Присоединение к чату" as UC4
  usecase "Отправка текстового сообщения" as UC5
  usecase "Отправка файла" as UC6
  usecase "Получение сообщений" as UC7
  usecase "Просмотр истории чата" as UC8
  usecase "Поиск чатов и пользователей" as UC9
  usecase "Управление профилем" as UC10
  usecase "Настройка уведомлений" as UC11
  usecase "Настройка безопасности чата" as UC12
  usecase "Добавление участников в чат" as UC13
  usecase "Назначение модератора чата" as UC14
  usecase "Блокировка участника чата" as UC15
  usecase "Шифрование чата" as UC16
  usecase "Загрузка файлов" as UC17
  usecase "Просмотр статусов сообщений" as UC18
  usecase "Управление политиками безопасности" as UC19
  usecase "Настройка параметров LDAP" as UC20
  usecase "Управление пользователями" as UC21

}

User -- UC1
User -- UC2
User -- UC3
User -- UC4
User -- UC5
User -- UC6
User -- UC7
User -- UC8
User -- UC9
User -- UC10
User -- UC11
User -- UC12
User -- UC13
User -- UC14
User -- UC15
User -- UC16
User -- UC17
User -- UC18

Admin -- UC19
Admin -- UC20
Admin -- UC21

UC2 ..> UC1 : includes
UC4 ..> UC3 : extends
UC5 ..> UC7 : includes
UC6 ..> UC17 : includes
UC13 ..> UC4 : includes
UC14 ..> UC13 : extends
UC15 ..> UC13 : extends
UC16 ..> UC3 : includes
UC18 ..> UC7 : includes

UC2 --> LDAP : authenticates

note bottom of UC16
Сквозное шифрование обеспечивает
конфиденциальность сообщений
end note

note bottom of UC19
Управление политиками безопасности
и уровнями доступа
end note

@enduml