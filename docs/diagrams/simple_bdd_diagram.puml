@startuml
!theme plain
title Блочная диаграмма определения: Структура мессенджера

package "Мессенджер Система" {

  rectangle "Пользователь" as User {
    userId: String
    username: String
    email: String
    role: UserRole
  }

  rectangle "Клиент" as Client {
    clientId: String
    platform: String
    version: String
  }

  rectangle "Сервер" as Server {
    serverId: String
    host: String
    port: Integer
  }

  rectangle "База данных" as Database {
    dbId: String
    type: DbType
    host: String
  }

  rectangle "Файловое хранилище" as FileStorage {
    storageId: String
    endpoint: String
    region: String
  }

  rectangle "Чат" as Chat {
    chatId: String
    name: String
    type: ChatType
    encrypted: Boolean
  }

  rectangle "Сообщение" as Message {
    messageId: String
    content: String
    timestamp: DateTime
    status: MessageStatus
  }

  rectangle "Файл" as File {
    fileId: String
    filename: String
    size: Long
    contentType: String
  }

}

User ||--o{ Chat : "участник"
User ||--o{ Message : "отправитель"
Client ||--|| Server : "соединение"
Server ||--o{ Database : "хранение"
Server ||--o{ FileStorage : "файлы"
Chat ||--o{ Message : "содержит"
Message ||--o{ File : "вложение"

@enduml